{
  "name": "white-label-generator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "dev:lan": "prisma generate && next dev --hostname 0.0.0.0 --port 3000",
    "build": "prisma generate && next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "mkdir -p prisma/data && touch prisma/data/label-projects.db && prisma db push",
    "prisma:studio": "prisma studio",
    "setup:runtime": "npm run prisma:migrate && npx playwright install chromium"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^6.19.3",
    "next": "^15.0.0",
    "playwright": "^1.46.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.52.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "prisma": "^6.19.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
